// Append these models to your existing schema.prisma file

model Referral {
  id          String   @id @default(uuid())
  referrerId  String   // The person sharing their link
  referrer    User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  buyerId     String   @unique // The new user who bought a ticket
  buyer       User     @relation("BuyerRelation", fields: [buyerId], references: [id])
  createdAt   DateTime @default(now())
}

model SocialPromoClaim {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  platform    String   // e.g., "X", "TikTok", "Instagram"
  postUrl     String
  viewCount   Int
  ticketsWon  Int
  claimedAt   DateTime @default(now())
}

model RaffleParticipant {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  ticketId    String   @unique // Must have a valid ticket to enter raffle
  isWinner    Boolean  @default(false)
  joinedAt    DateTime @default(now())
}
