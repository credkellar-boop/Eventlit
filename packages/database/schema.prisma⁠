datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------------------------
// CORE TICKETING & USER MODELS
// ----------------------------------------------------------------------

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  name               String?
  walletAdd          String?             @unique // For Web3 / Monad ticket gating
  
  // Base Relations
  orders             Order[]
  events             Event[]             // Events this user has organized
  
  // Viral & Promo Relations
  referralsMade      Referral[]          @relation("ReferrerRelation")
  referralsCompleted Referral[]          @relation("BuyerRelation")
  socialPromoClaims  SocialPromoClaim[]
  raffleEntries      RaffleParticipant[]

  createdAt          DateTime            @default(now())
}

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  location      String
  startTime     DateTime
  
  organizerId   String
  organizer     User                @relation(fields: [organizerId], references: [id])
  
  ticketTiers   TicketTier[]
  orders        Order[]
  raffleEntries RaffleParticipant[]

  createdAt     DateTime            @default(now())
}

model TicketTier {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  name        String   // e.g., "Early Bird", "VIP"
  price       Int      // Stored in cents (e.g., $20.00 = 2000)
  capacity    Int
  
  reserved    Int      @default(0) // Tracks current lock/holding counter for HFT
  sold        Int      @default(0)
}

model Order {
  id          String      @id @default(uuid())
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  
  status      OrderStatus @default(PENDING)
  totalAmount Int
  
  createdAt   DateTime    @default(now())
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

// ----------------------------------------------------------------------
// VIRAL GROWTH & PROMO MODELS
// ----------------------------------------------------------------------

model Referral {
  id          String   @id @default(uuid())
  
  referrerId  String   // The person sharing their link
  referrer    User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  
  buyerId     String   @unique // The new user who bought a ticket
  buyer       User     @relation("BuyerRelation", fields: [buyerId], references: [id])
  
  createdAt   DateTime @default(now())
}

model SocialPromoClaim {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  platform    String   // e.g., "X", "TikTok", "Instagram"
  postUrl     String
  viewCount   Int
  ticketsWon  Int
  
  claimedAt   DateTime @default(now())
}

model RaffleParticipant {
  id          String   @id @default(uuid())
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  ticketId    String   @unique // Must have a valid ticket/order ID to enter the raffle
  isWinner    Boolean  @default(false)
  
  joinedAt    DateTime @default(now())
}
