datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------------------------
// USER & CORE SUBSCRIPTION MECHANICS
// ----------------------------------------------------------------------

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  name               String?
  walletAdd          String?             @unique // Monad wallet link
  
  // Base Relations
  orders             Order[]
  events             Event[]             // Events this user is organizing
  
  // Recurring Membership Plan Link
  subscription       Subscription?

  // Growth, Secondary Market & Identity Relations
  referralsMade      Referral[]          @relation("ReferrerRelation")
  referralsCompleted Referral[]          @relation("BuyerRelation")
  socialPromoClaims  SocialPromoClaim[]
  raffleEntries      RaffleParticipant[]
  resaleListings     SecondaryMarketListing[]
  onChainIdentities  OnChainIdentity[]        

  createdAt          DateTime            @default(now())
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id])
  tier      SubscriptionTier @default(NONE)
  status    SubStatus        @default(INACTIVE)
  
  stripeSubId String?        @unique // For payment gateway webhooks
  currentPeriodEnd DateTime
  
  updatedAt DateTime         @updatedAt
  createdAt DateTime         @default(now())
}

enum SubscriptionTier {
  NONE
  LIT_FAN
  ORGANIZER_PRO
  FESTIVAL_SCALE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INACTIVE
}

// ----------------------------------------------------------------------
// EVENT ENGINE & TICKETING
// ----------------------------------------------------------------------

model Event {
  id              String              @id @default(uuid())
  title           String
  description     String
  location        String              
  startTime       DateTime
  
  isLivestreamed  Boolean             @default(false)
  streamUrl       String?             
  
  organizerId     String
  organizer       User                @relation(fields: [organizerId], references: [id])
  
  ticketTiers     TicketTier[]
  orders          Order[]
  raffleEntries   RaffleParticipant[]

  createdAt       DateTime            @default(now())
}

model TicketTier {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  name        String   
  price       Int      
  capacity    Int
  
  isVirtual   Boolean  @default(false) 
  isPreOrder  Boolean  @default(false) 
  
  reserved    Int      @default(0) 
  sold        Int      @default(0)
}

model Order {
  id          String      @id @default(uuid())
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  
  status      OrderStatus @default(PENDING)
  totalAmount Int
  
  resaleListingId String? @unique
  resaleListing   SecondaryMarketListing? @relation(fields: [resaleListingId], references: [id])

  createdAt   DateTime    @default(now())
}

enum OrderStatus {
  PRE_ORDERED 
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

// ----------------------------------------------------------------------
// SECONDARY MARKET, IDENTITY, & PROMOS
// ----------------------------------------------------------------------

model SecondaryMarketListing {
  id              String        @id @default(uuid())
  sellerId        String
  seller          User          @relation(fields: [sellerId], references: [id])
  originalOrderId String 
  askingPrice     Int    
  status          ListingStatus @default(ACTIVE)
  buyerOrder      Order?        
  createdAt       DateTime      @default(now())
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model OnChainIdentity {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  platform         String   
  socialHandle     String
  contractAddress  String   
  verifiedOnChain  Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model Referral {
  id          String   @id @default(uuid())
  referrerId  String   
  referrer    User     @relation("ReferrerRelation", fields: [referrerId], references: [id])
  buyerId     String   @unique 
  buyer       User     @relation("BuyerRelation", fields: [buyerId], references: [id])
  createdAt   DateTime @default(now())
}

model SocialPromoClaim {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  platform    String   
  postUrl     String
  viewCount   Int
  ticketsWon  Int
  claimedAt   DateTime @default(now())
}

model RaffleParticipant {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  ticketId    String   @unique 
  isWinner    Boolean  @default(false)
  joinedAt    DateTime @default(now())
}
